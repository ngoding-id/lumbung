_gitname="kvitals"
pkgname=plasma6-applets-kvitals
pkgver=2.11.0
pkgrel=1
pkgdesc="A lightweight KDE Plasma 6 panel widget that displays live system vitals directly in your top bar."
arch=(any)
url="https://github.com/yassine20011/$_gitname"
license=(GPL-3.0)
depends=('libplasma')
source=("$pkgname-$pkgver.tar.gz::https://github.com/yassine20011/$_gitname/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('77d9f868d64f7c74e7cf5a2ca4caf400d6c36f1f27319b138891dc8f1151222c')
provides=('plasma6-applets-kvitals-git')
conflicts=('plasma6-applets-kvitals-git')

package() {
  _path="$pkgdir/usr/share/plasma/plasmoids/org.kde.plasma.kvitals"
  mkdir -p "$_path"
  cp -r "$_gitname-$pkgver/contents" "$_path"
  cp -r "$_gitname-$pkgver/metadata.json" "$_path"
  install -Dm 644 "$_gitname-$pkgver/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
