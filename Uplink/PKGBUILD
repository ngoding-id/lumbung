# Maintainer: ngoding-id/lumbung <defy-disarray-jury at duck dot com>

pkgname=Uplink
pkgver=2026.7.1
pkgrel=1
pkgdesc="A fast, secure, IRCv3-featured IRC client built with Qt6 and C++."
arch=('x86_64')
url="https://github.com/noderelay/UplinkIRC"
license=('GPL-3.0-only')
install=${pkgname}.install
depends=(
    'qt6-base'
    'qt6-svg'
    'qt6-websockets'
    'qtkeychain-qt6'
    'tomlplusplus'
    'hicolor-icon-theme'
)
makedepends=(
    'cmake'
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/noderelay/UplinkIRC/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('3a5940f86a21702d6c6480c62b73ff6d6f180f53176b498e67c23271f43f245c')

build() {
  cd "UplinkIRC-$pkgver"

  cmake -B build -S . \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DUPLINK_VENDOR_DEPS=OFF \
    -DUPLINK_BUILD_TESTS=OFF

  cmake --build build
}

package() {
  cd "UplinkIRC-$pkgver"

  DESTDIR="$pkgdir" cmake --install build

  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
